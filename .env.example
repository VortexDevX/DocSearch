# ============================================
# DocSearch - Environment Configuration
# Copy this file to .env and update values
# ============================================

# Server Configuration
# Options: development, production
NODE_ENV=development
PORT=3000

# Database
# Path to SQLite database file
DB_PATH=./database/doctors.db

# Pagination
# Number of doctors per page (default: 12)
PAGE_SIZE=12
# Maximum allowed page size (default: 50)
MAX_PAGE_SIZE=50

# Rate Limiting
# Time window in milliseconds (default: 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# Security
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://dr-search.netlify.app

# Logging
# Options: error, warn, info, debug
LOG_LEVEL=info